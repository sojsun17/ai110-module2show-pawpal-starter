classDiagram
    class Task {
        +id: int
        +description: str
        +due_time: str
        +duration_mins: int
        +priority: str
        +frequency: str
        +is_completed: bool
        +mark_complete() void
    }

    class Pet {
        +name: str
        +species: str
        +age: int
        +tasks: List~Task~
        +add_task(task: Task) void
    }

    class Owner {
        +name: str
        +pets: List~Pet~
        +add_pet(pet: Pet) void
    }

    class Scheduler {
        +pets: List~Pet~
        +add_pet(pet: Pet) void
        +_time_to_minutes(time_str: str) int
        +get_all_tasks() List~Tuple~
        +get_upcoming_tasks() List~Tuple~
        +check_conflicts(new_task: Task) bool
    }

    Pet "1" *-- "0..*" Task : has
    Scheduler "1" o-- "0..*" Pet : tracks
    Owner "1" o-- "0..*" Pet : manages
    Owner --> Scheduler : uses
    Scheduler ..> Task : validates

