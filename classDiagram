classDiagram
    class Task {
        +description: str
        +due_time: datetime
        +duration_mins: int
        +priority: str
        +is_completed: bool
        +mark_complete() void
    }

    class Pet {
        +name: str
        +species: str
        +tasks: List~Task~
        +add_task(task: Task) void
    }

    class Owner {
        +name: str
        +pets: List~Pet~
    }

    class Scheduler {
        +pets: List~Pet~
        +add_pet(pet: Pet) void
        +get_all_tasks() List~Task~
        +get_upcoming_tasks(reference_time: datetime) List~Task~
        +check_conflicts() List~Task~
    }

    Pet "1" *-- "0..*" Task : has
    Scheduler "1" o-- "0..*" Pet : manages
    Owner "1" o-- "0..*" Pet : owns
    Owner --> Scheduler : uses
    Scheduler ..> Task : processes